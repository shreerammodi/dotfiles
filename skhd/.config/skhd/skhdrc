# modes: default plus captured resize (alt-w) and stack (alt-c) modes. 'default' must be first.
:: default
:: resize @
:: stack @

alt - t : osascript -e 'tell application "Ghostty" to new window'

alt - r : yabai -m space --rotate 90
alt - s : yabai -m space --layout "$(yabai -m query --spaces --space | jq -r 'if .type == "stack" then "bsp" else "stack" end')"
alt - f : yabai -m window --toggle zoom-fullscreen

alt - z : yabai -m window --insert east
alt - v : yabai -m window --insert south
alt - x : yabai -m window --insert stack

alt - h : yabai -m window --focus west  || yabai -m display --focus west
alt - j : yabai -m window --focus south || yabai -m window --focus stack.next || yabai -m window --focus stack.first
alt - k : yabai -m window --focus north || yabai -m window --focus stack.prev || yabai -m window --focus stack.last
alt - l : yabai -m window --focus east  || yabai -m display --focus east

shift + alt - h : yabai -m window --warp west  || yabai -m window --display west  --focus
shift + alt - j : yabai -m window --warp south
shift + alt - k : yabai -m window --warp north
shift + alt - l : yabai -m window --warp east  || yabai -m window --display east  --focus

alt - w ; resize
alt - c ; stack

resize < h : yabai -m window --resize right:-60:0  || yabai -m window --resize left:-60:0
resize < j : yabai -m window --resize bottom:0:60  || yabai -m window --resize top:0:60
resize < k : yabai -m window --resize bottom:0:-60 || yabai -m window --resize top:0:-60
resize < l : yabai -m window --resize right:60:0   || yabai -m window --resize left:60:0

resize < e : yabai -m space --balance

resize < escape ; default
resize < alt - w ; default

# stack mode: pull the neighbouring window in <dir> onto the focused window,
# merging them into a stack that occupies the focused window's frame.
stack < h : yabai -m window --stack west
stack < j : yabai -m window --stack south
stack < k : yabai -m window --stack north
stack < l : yabai -m window --stack east

# cycle within the stack, and unstack the focused window (float/unfloat is the
# only reliable way out: stack members share a frame, so --warp is a no-op).
stack < n : yabai -m window --focus stack.next || yabai -m window --focus stack.first
stack < p : yabai -m window --focus stack.prev || yabai -m window --focus stack.last
stack < u : yabai -m window --toggle float && yabai -m window --toggle float

stack < escape ; default
stack < alt - c ; default

alt - p : yabai -m display --focus 2
alt - n : yabai -m display --focus 1

shift + alt - p : yabai -m window --display 2 --focus
shift + alt - n : yabai -m window --display 1 --focus

alt - i : yabai -m space --focus next
alt - o : yabai -m space --focus prev

shift + alt - i : yabai -m window --space next
shift + alt - o : yabai -m window --space prev

alt - m : open -a "Mission Control"

alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

shift + alt - 1 : yabai -m window --space 1
shift + alt - 2 : yabai -m window --space 2
shift + alt - 3 : yabai -m window --space 3
shift + alt - 4 : yabai -m window --space 4
shift + alt - 5 : yabai -m window --space 5
shift + alt - 6 : yabai -m window --space 6
shift + alt - 7 : yabai -m window --space 7
shift + alt - 8 : yabai -m window --space 8
shift + alt - 9 : yabai -m window --space 9
