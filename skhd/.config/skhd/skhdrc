# skhd -> yabai. Mirrors the aerospace config: Alt is the modifier, no modes.
# Letters are resolved through the active keyboard layout (Colemak), so they
# match the aerospace bindings. Punctuation uses keycodes (physical); on Colemak
# semicolon sits on a different physical key - adjust if it feels wrong.

# --- launchers (aerospace alt-t / alt-semicolon) ---
alt - t    : open -a Ghostty

# --- layout (alt-r rotate, alt-s toggle stack, alt-f fullscreen) ---
alt - r : yabai -m space --rotate 90
alt - s : yabai -m space --layout "$(yabai -m query --spaces --space | jq -r 'if .type == "stack" then "bsp" else "stack" end')"
alt - f : yabai -m window --toggle zoom-fullscreen

# --- split (aerospace alt-z horizontal / alt-v vertical) ---
alt - z : yabai -m window --insert east
alt - v : yabai -m window --insert south

# --- focus (alt-hjkl); in a stack cycle the stack, else cross to the display at the edge ---
alt - h : yabai -m window --focus west  || yabai -m display --focus west
alt - j : yabai -m window --focus south || yabai -m window --focus stack.next || yabai -m window --focus stack.first
alt - k : yabai -m window --focus north || yabai -m window --focus stack.prev || yabai -m window --focus stack.last
alt - l : yabai -m window --focus east  || yabai -m display --focus east

# --- move / warp window (alt-shift-hjkl) ---
shift + alt - h : yabai -m window --swap west  || yabai -m window --display west  --focus
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east  || yabai -m window --display east  --focus

# --- resize (aerospace alt-minus / alt-equal, smart-ish via bottom-right corner) ---
alt - 0x1B : yabai -m window --resize bottom_right:-60:-60
alt - 0x18 : yabai -m window --resize bottom_right:60:60

# --- displays (aerospace alt-d split into p/n; 1-indexed by arrangement) ---
alt - p : yabai -m display --focus 1
alt - n : yabai -m display --focus 2

shift + alt - p : yabai -m window --display 1 --focus
shift + alt - n : yabai -m window --display 2 --focus

# --- workspaces: next/prev with wrap (aerospace alt-i / alt-o) ---
alt - i : yabai -m space --focus next || yabai -m space --focus first
alt - o : yabai -m space --focus prev || yabai -m space --focus last

# move window to next/prev space with wrap (aerospace alt-shift-i / alt-shift-o)
shift + alt - i : yabai -m window --space next || yabai -m window --space first
shift + alt - o : yabai -m window --space prev || yabai -m window --space last

# --- mission control: native macOS (crisp real Spaces) ---
alt - m : open -a "Mission Control"

# --- switch to workspace (alt-1..9) ---
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# --- move window to workspace (alt-shift-1..9) ---
shift + alt - 1 : yabai -m window --space 1
shift + alt - 2 : yabai -m window --space 2
shift + alt - 3 : yabai -m window --space 3
shift + alt - 4 : yabai -m window --space 4
shift + alt - 5 : yabai -m window --space 5
shift + alt - 6 : yabai -m window --space 6
shift + alt - 7 : yabai -m window --space 7
shift + alt - 8 : yabai -m window --space 8
shift + alt - 9 : yabai -m window --space 9
