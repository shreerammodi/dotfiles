#!/usr/bin/env sh

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

yabai -m config layout bsp

yabai -m config mouse_modifier ctrl
yabai -m config mouse_drop_action stack

yabai -m config top_padding    5
yabai -m config bottom_padding 5
yabai -m config left_padding   5
yabai -m config right_padding  5
yabai -m config window_gap     5

# split behaviour: let yabai pick the axis by aspect ratio (i3-like feel)
yabai -m config split_type auto

# mouse (aerospace moved the mouse to the focused monitor)
yabai -m config mouse_follows_focus on
yabai -m config focus_follows_mouse off

# --- rules (aerospace app_rule: keepassxc floats) ---
yabai -m rule --add app="^KeePassXC$" manage=off

# --- borders (aerospace after-startup-command) ---
borders active_color=0xffc6daff inactive_color=0xff646464 width=5.0 2>/dev/null &

echo "yabai configuration loaded"
